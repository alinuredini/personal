---
const links = [
  { text: "Work inquiries", url: "https://8-reasons.com/kontakt" },
  { text: "LinkedIn", url: "https://linkedin.com/in/alinuredini" },
  { text: "Instagram", url: "https://instagram.com/alinuredini" },
];
---

<section id="contact" class="contact-card">
  <div class="contact-cta">
    <h3>Wanna work together? Have a chat?<br />Let's talk!</h3>
  </div>

  <div class="contact-links">
    {links.map((link) => (
      <a href={link.url} target="_blank" rel="noopener noreferrer" class="contact-link">
        <svg class="arrow-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7" />
          <path d="M7 7h10v10" />
        </svg>
        <span>{link.text}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .contact-card {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--color-purple);
    border-radius: 20px;
    padding: 64px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .contact-cta h3 {
    font-family: var(--font-sans);
    font-size: 48px;
    font-weight: 400;
    color: var(--color-white);
    line-height: 1.4;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-white);
    width: fit-content;
    transition: opacity 0.3s ease;
  }

  .contact-link:hover {
    opacity: 0.7;
  }

  .arrow-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.44, 0, 0.56, 1);
  }

  .contact-link:hover .arrow-icon {
    transform: rotate(45deg);
  }

  @media (max-width: 900px) {
    .contact-card {
      padding: 40px;
    }

    .contact-cta h3 {
      font-size: clamp(28px, 5vw, 48px);
    }
  }
</style>
