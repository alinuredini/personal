---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ali Nuredini | UX Designer Specializing in User-Centered Design",
  description = "Personal site of Ali Nuredini, a UX Designer dedicated to creating intuitive, user-centered experiences. Explore my portfolio and discover how I can help enhance your digital products."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,400;0,700;1,400;1,700&family=Manrope:wght@300;400;500;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap');

  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --color-bg: #0a0a0a;
    --color-bg-dark: #000000;
    --color-text: #ffffff;
    --color-text-muted: rgba(255, 255, 255, 0.7);
    --color-green: #c3e0b2;
    --color-olive: #282919;
    --color-olive-alt: #484a2d;
    --color-purple: #4a2d44;
    --color-blue: #4c6085;
    --color-rose: #b05b60;

    --font-sans: 'Manrope', system-ui, -apple-system, sans-serif;
    --font-display: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
    --font-mono: 'Space Mono', monospace;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.5;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  ::selection {
    background: var(--color-rose);
    color: var(--color-text);
  }
</style>
