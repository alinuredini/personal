---
const people = [
  { name: "Ema Ljačković", url: "https://www.linkedin.com/in/ema-ljackovic-0b073221a/" },
  { name: "Alexander Varro", url: "https://www.linkedin.com/in/alexandervarro" },
  { name: "Francesca Cignola", url: "https://www.linkedin.com/in/francescacignola" },
  { name: "Mihaly Peterfy", url: "https://www.linkedin.com/in/michaelpeterfy/" },
  { name: "Daniela Raisich", url: "https://www.linkedin.com/in/daniela-r-29b923320/" },
  { name: "Victor Getz", url: "https://www.linkedin.com/in/victor-getz-359903b2" },
  { name: "Alexander Lorenz", url: "https://www.linkedin.com/in/alexis-whte" },
  { name: "Pablo Uribe", url: "https://www.linkedin.com/in/pablouribebotero" },
];
---

<section class="hero">
  <h1 class="hero-name">Ali Nuredini</h1>

  <div class="hero-row">
    <div class="hero-tagline">
      <h4>Germany based Designer with an infinite love for photography, specialised in UX + UI & DesignOps.</h4>
    </div>

    <div class="people-card">
      <div class="people-header">
        <h3 class="people-title">People I love(d) working with:</h3>
        <span class="people-subtitle">(This list is non-exhaustive)</span>
      </div>
      <div class="people-grid">
        {people.map((person) => (
          <a href={person.url} target="_blank" rel="noopener noreferrer" class="person-link">
            <svg class="arrow-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7" />
              <path d="M7 7h10v10" />
            </svg>
            <span>{person.name}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 70px;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-name {
    font-family: var(--font-sans);
    font-size: 200px;
    font-weight: 300;
    color: var(--color-white);
    letter-spacing: -8px;
    line-height: 200px;
  }

  .hero-row {
    display: flex;
    flex-direction: row;
    gap: 48px;
    align-items: flex-end;
  }

  .hero-tagline {
    flex: 0 0 526px;
  }

  .hero-tagline h4 {
    font-family: var(--font-sans);
    font-size: 32px;
    font-weight: 400;
    color: var(--color-white);
    line-height: 1.2;
  }

  .people-card {
    flex: 1;
    background: var(--color-purple);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .people-header {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .people-title {
    font-family: var(--font-sans);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-white);
  }

  .people-subtitle {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-white);
    letter-spacing: -0.12px;
    text-transform: uppercase;
  }

  .people-grid {
    display: grid;
    grid-template-rows: repeat(4, auto);
    grid-auto-flow: column;
    gap: 6px 24px;
  }

  .person-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-white);
    transition: opacity 0.3s ease;
  }

  .person-link:hover {
    opacity: 0.8;
  }

  .arrow-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.44, 0, 0.56, 1);
  }

  .person-link:hover .arrow-icon {
    transform: rotate(45deg);
  }

  @media (max-width: 1200px) {
    .hero-name {
      font-size: clamp(60px, 14vw, 200px);
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .hero-row {
      flex-direction: column;
      gap: 32px;
      align-items: stretch;
    }

    .hero-tagline {
      flex: unset;
    }

    .hero-tagline h4 {
      font-size: clamp(22px, 3.5vw, 32px);
    }
  }

  @media (max-width: 600px) {
    .people-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
